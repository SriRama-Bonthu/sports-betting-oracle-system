# The private key of the wallet that will act as the oracle
# IMPORTANT: This must be a dedicated, separate wallet funded with testnet ETH
ORACLE_PRIVATE_KEY=

# RPC URL for connecting to the blockchain (e.g., your local Hardhat node)
RPC_URL=http://hardhat:8545

# Deployed address of the SportsOracle contract
ORACLE_CONTRACT_ADDRESS=

# Optional: deployed BettingMarket contract address (for frontend read helpers)
BETTING_MARKET_CONTRACT_ADDRESS=

# Optional: TheSportsDB endpoint for fetching live data
SPORTS_API_BASE_URL=https://www.thesportsdb.com/api/v1/json/3

# Service port
PORT=3001
